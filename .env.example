# ==========================================================
# Casa da Chita — Variáveis de ambiente
# ==========================================================
# Copia esse arquivo pra .env.local e preenche.
# Em produção, configura via Vercel Dashboard ou `vercel env add`.

# ============================
# Meta Pixel + Conversions API
# ============================
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# ============================
# Ticto Webhook (checkout ativo a partir de 20/05/2026)
# ============================
# Token configurado no painel da Ticto: Configurações → Postbacks → Token
# Ticto envia esse token no campo `token` do body do webhook.
TICTO_WEBHOOK_TOKEN=

# ============================
# Cakto Webhook (legacy — manter ativo até cutover total pro Ticto)
# ============================
CAKTO_WEBHOOK_SECRET=

# ============================
# WhatsApp Cloud API (Meta)
# ============================
# Encontra em business.facebook.com → WhatsApp Manager → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_ID=
# Versão da Graph API (deixar default ou subir conforme Meta atualiza)
WHATSAPP_API_VERSION=v21.0

# ============================
# Resend (e-mail)
# ============================
# Cria em resend.com, gera API key
RESEND_API_KEY=
# E-mail remetente (precisa do domínio verificado no Resend com DKIM/SPF/DMARC)
EMAIL_FROM=Jacira <jacira@casadachita.com.br>
EMAIL_REPLY_TO=jacira@casadachita.com.br

# ============================
# Vercel KV (estado dos fluxos)
# ============================
# Criado automaticamente quando habilita Vercel KV no projeto
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ============================
# Admin (proteção do painel)
# ============================
# Senha pra acessar /admin (broadcast, dashboard interno)
ADMIN_PASSWORD=
# Secret pra assinar cookies de sessão admin (32+ chars aleatórios)
ADMIN_SESSION_SECRET=

# ============================
# Cron Jobs (Vercel)
# ============================
# Secret pra autenticar chamadas dos crons internos
CRON_SECRET=
